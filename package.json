{
  "name": "@love-test/mobile",
  "packageManager": "bun@1.3.9",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "clean": "bunx expo start --clear",
    "start": "bunx expo start",
    "start-web": "bunx expo start --web",
    "start-web-dev": "DEBUG=expo* bunx expo start --web",
    "build": "bunx eas-cli build -p android",
    "prebuild": "bunx expo prebuild --platform android --clean",
    "preview": "bunx eas-cli build --profile preview --platform android",
    "dev": "bunx expo run:android",
    "update": "bunx eas-cli update --channel production",
    "update:dev": "bunx eas-cli update --channel preview",
    "update:main": "bunx eas-cli update --channel main",
    "submit:android": "bunx eas-cli submit -p android",
    "android": "bunx expo start --android",
    "ios": "bunx expo start --ios",
    "lint": "expo lint",
    "affiliates:expiry": "node scripts/check-affiliate-expiry.mjs",
    "affiliates:expiry:dry": "node scripts/check-affiliate-expiry.mjs --dry-run",
    "affiliates:expiry:bounce": "node scripts/check-affiliate-expiry.mjs --bounce"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@nkzw/create-context-hook": "^1.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.83.0",
    "@ungap/structured-clone": "^1.3.0",
    "expo": "~54.0.27",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "~15.0.9",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.17",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.13.0",
    "lucide-react-native": "^0.475.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-notify-kit": "^9.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "expo-doctor": "^1.18.22",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
