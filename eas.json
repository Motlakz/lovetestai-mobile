{
  "cli": {
    "version": ">= 18.12.3",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "bun": "1.3.9",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "bun": "1.3.9",
      "distribution": "internal"
    },
    "production": {
      "bun": "1.3.9",
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "internal": {
      "android": {
        "applicationId": "com.lovetestai",
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "production": {
      "android": {
        "applicationId": "com.lovetestai",
        "track": "production",
        "releaseStatus": "completed",
        "changesNotSentForReview": true
      },
      "ios": {
        "bundleIdentifier": "com.lovetestai"
      }
    }
  }
}
