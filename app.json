{
  "expo": {
    "name": "Love Test AI",
    "slug": "lovetestai",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lovetestai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lovetestai"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lovetestai",
      "permissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Love Test AI to save your exported creation cards to your photo library.",
          "savePhotosPermission": "Allow Love Test AI to save your exported creation cards to your photo library."
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      "expo-sqlite",
      [
        "./plugins/with-admob-android",
        {
          "androidAppId": "ca-app-pub-1422001850914649~1593954742"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d1a2defc-de1f-40eb-a61f-06d7ce6a6adf"
      }
    }
  }
}
